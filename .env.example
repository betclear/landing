# Firebase (client-side; measurementId is optional)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Database password from Supabase Dashboard → Project Settings → Database
# Used by: npm run db:migrate
SUPABASE_DB_PASSWORD=
# Or provide a full connection string instead:
# DATABASE_URL=postgresql://postgres:...@db.<project-ref>.supabase.co:5432/postgres
ADMIN_PASSWORD=
BLOCKLIST_API_TOKEN=
ADGUARD_BASE_URL=https://dns.betclear.app
ADGUARD_USERNAME=
ADGUARD_PASSWORD=

# Site URL used for Stripe Checkout redirects (no trailing slash)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Stripe (server-only except publishable key)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Created by: npm run stripe:setup
STRIPE_PRICE_TEST=
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_ANNUAL=

# Optional override for webhook registration script
STRIPE_WEBHOOK_URL=https://www.betclear.app/api/webhooks/stripe
