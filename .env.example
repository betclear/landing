# Firebase (client-side; measurementId is optional)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Optional after Supabase custom domain (e.g. auth.betclear.app) is active:
# NEXT_PUBLIC_SUPABASE_URL=https://auth.betclear.app
SUPABASE_SERVICE_ROLE_KEY=

# Database password from Supabase Dashboard → Project Settings → Database
# Used by: npm run db:migrate
SUPABASE_DB_PASSWORD=
# Or provide a full connection string instead:
# DATABASE_URL=postgresql://postgres:...@db.<project-ref>.supabase.co:5432/postgres
ADMIN_PASSWORD=
BLOCKLIST_API_TOKEN=
ADGUARD_BASE_URL=https://dns.betclear.app
ADGUARD_USERNAME=
ADGUARD_PASSWORD=

# Canonical site URL for Stripe/auth redirects (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Alias supported by existing paywall helpers
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Stripe (server-only except publishable key)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Created by: npm run stripe:setup
STRIPE_PRICE_TEST=
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_ANNUAL=

# Optional override for webhook registration script
STRIPE_WEBHOOK_URL=https://www.betclear.app/api/webhooks/stripe

# Apple .mobileconfig CMS/PKCS#7 signing (server only — never NEXT_PUBLIC_*)
# Prefer one of: PEM env vars, absolute file paths, or files under secrets/profile-signing/
# PROFILE_SIGNING_CERT=
# PROFILE_SIGNING_KEY=
# PROFILE_SIGNING_CHAIN=
# PROFILE_SIGNING_CERT_PATH=
# PROFILE_SIGNING_KEY_PATH=
# PROFILE_SIGNING_CHAIN_PATH=
# PROFILE_SIGNING_DIR=secrets/profile-signing
